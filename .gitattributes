# C#プロジェクト用の.gitattributes設定

# テキストファイルの改行コードを統一（LFに統一）
* text=auto eol=lf

# C#関連ファイル
*.cs text eol=lf
*.csproj text eol=lf
*.sln text eol=lf
*.props text eol=lf
*.targets text eol=lf
*.config text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.txt text eol=lf
*.md text eol=lf

# バイナリファイルとして扱う
*.dll binary
*.exe binary
*.pdb binary
*.so binary
*.dylib binary
*.a binary
*.lib binary
*.obj binary
*.o binary

# 画像ファイル
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.bmp binary
*.ico binary
*.svg text eol=lf

# アーカイブファイル
*.zip binary
*.tar binary
*.gz binary
*.rar binary
*.7z binary

# Visual Studio関連ファイル
*.user text eol=lf
*.suo binary
*.cache binary
*.log text eol=lf

# NuGet関連
*.nupkg binary
*.snupkg binary

# その他の設定ファイル
*.editorconfig text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf
