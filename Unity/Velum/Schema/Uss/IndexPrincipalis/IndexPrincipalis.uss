.indexprincipalis-root {
    flex-direction: row;
    width: 100%;
    height: 100%;
}

.indexprincipalis-panel {
    width: 380px;
    height: 100%;

    justify-content: center;
    align-items: flex-start;

    padding-left: 20px;
    flex-direction: column;
}

.indexprincipalis-button {
    height: 64px;
    margin-bottom: 16px;
    width: 260px;
    font-size: 24px;
    unity-text-align: middle-left;
}